@page
@model BookStore.Pages.Books.IndexModel

<h2 class="mb-4">Books</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Price</th>
            <th>Category</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model.Books)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>₹@book.Price</td>
                <td>@book.Category?.Name</td>
            </tr>
        }
    </tbody>
</table>